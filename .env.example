# Original Botanica Membership Dashboard — environment variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to git.

# ─────────────────────────────────────────────────────────────────────────────
# Site
# ─────────────────────────────────────────────────────────────────────────────

# Fully-qualified site URL. Used by Next.js for metadata, OG images,
# and Stripe redirect URLs. In Vercel previews this auto-resolves;
# locally set to http://localhost:3000.
NEXT_PUBLIC_SITE_URL=https://members.originalbotanica.com

# ─────────────────────────────────────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────────────────────────────────────

# Public URL of your Supabase project (https://<ref>.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Publishable anon key — safe to expose to the browser, respects RLS
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — SERVER ONLY, never expose to the browser
# Used for admin operations from API routes / server actions
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Stripe
# ─────────────────────────────────────────────────────────────────────────────

# Secret API key — sk_test_... in development, sk_live_... in production
STRIPE_SECRET_KEY=

# Webhook signing secret — whsec_... from stripe-cli or the Vercel webhook config
STRIPE_WEBHOOK_SECRET=

# Price IDs for the two membership SKUs ($24.99/mo and $199/yr)
# Both should have a 7-day trial configured on the price object.
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=

# ─────────────────────────────────────────────────────────────────────────────
# Anthropic (Claude)
# ─────────────────────────────────────────────────────────────────────────────

# API key for the AI astrologer, tarot interpretation, ritual suggestions
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# AstrologyAPI.com
# ─────────────────────────────────────────────────────────────────────────────

# Used for natal chart calculations, transits, compatibility.
# If unset, the astrology features fall back to mocked data so the
# rest of the app still boots in development.
ASTROLOGY_API_USER_ID=
ASTROLOGY_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Resend (transactional email)
# ─────────────────────────────────────────────────────────────────────────────

RESEND_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Craft Commerce sync (member discount group)
# ─────────────────────────────────────────────────────────────────────────────

# Webhook endpoint on the Craft Commerce side that listens for
# member-started / member-stopped events. Glenn will provide this URL.
CRAFT_COMMERCE_MEMBER_WEBHOOK_URL=
CRAFT_COMMERCE_MEMBER_WEBHOOK_SECRET=
